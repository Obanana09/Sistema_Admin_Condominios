CREATE TABLE Casas (
    id_casa INTEGER PRIMARY KEY AUTOINCREMENT,
    numero_casa INTEGER NOT NULL,
    nombre_encargado TEXT NOT NULL,
    telefono TEXT NOT NULL,
    estado_pago TEXT NOT NULL -- 'Pagado' o 'Pendiente'
);

